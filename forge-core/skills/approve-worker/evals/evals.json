{
  "skill_name": "approve-worker",
  "evals": [
    {
      "id": 1,
      "prompt": "/approve-worker 2026-05-24-v1-my-task codex-critic mcp__codex__codex ${FORGE_ROOT:-$HOME/forge}-outputs/13-multiagent/tasks/2026-05-24-v1-my-task/**",
      "expected_output": "HMAC 서명 토큰 파일 생성: ${FORGE_ROOT:-$HOME/forge}-outputs/.claude/audit/approvals/2026-05-24-v1-my-task-{nonce}.yaml",
      "expectations": [
        "approvals/{task_id}-{nonce}.yaml 파일 생성됨",
        "파일에 _signature 필드 포함",
        "expires_at = issued_at + 3600s",
        "audit log에 TOKEN_ISSUED 이벤트 기록",
        "[APPROVED] 출력으로 종료"
      ]
    },
    {
      "id": 2,
      "prompt": "PROC_PID_OVERRIDE=999999 python3 $HOME/.claude/skills/approve-worker/scripts/approve-worker-sign.py --task test --worker codex-critic --tools Read --paths /tmp",
      "expected_output": "Production 환경에서 PROC_PID_OVERRIDE 무효화 + audit log 기록",
      "expectations": [
        "CI=false, FORGE_TEST_MODE 미설정 환경에서 PROC_PID_OVERRIDE 자동 삭제",
        "audit log에 PROC_PID_OVERRIDE_BLOCKED 이벤트 기록",
        "PID lineage는 실제 PPID로 검증됨"
      ]
    },
    {
      "id": 3,
      "prompt": "/approve-worker test-task codex-critic * /tmp/**",
      "expected_output": "wildcard * in allowed_tools → exit 2 + BLOCKED 출력",
      "expectations": [
        "exit code 2로 종료",
        "[BLOCKED] allowed_tools wildcard '*' not permitted 출력",
        "approvals 파일 생성 안 됨",
        "audit log에 WILDCARD_BLOCKED 이벤트 기록"
      ]
    }
  ]
}
